# OpenHand environment variables.
# Copy to `.env` and fill in real values. DO NOT commit `.env`.

# ---------------------------------------------------------------------------
# Core / agent
# ---------------------------------------------------------------------------

# Default LLM provider: openai | anthropic | ollama | custom
OPENHAND_LLM_PROVIDER=openai
OPENHAND_LLM_MODEL=gpt-4o-mini
# Request timeout in ms for any single LLM call.
OPENHAND_LLM_TIMEOUT_MS=30000
# Where the local config/state lives.
OPENHAND_HOME=~/.openhand

# ---------------------------------------------------------------------------
# LLM providers (only fill in the ones you use)
# ---------------------------------------------------------------------------

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=

# For Ollama or any OpenAI-compatible endpoint
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_API_KEY=ollama

# ---------------------------------------------------------------------------
# apps/server
# ---------------------------------------------------------------------------

SERVER_HOST=0.0.0.0
SERVER_PORT=3001
# CORS allowlist, comma separated; use "*" only for local dev.
SERVER_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# apps/web
# ---------------------------------------------------------------------------

VITE_API_BASE_URL=http://localhost:3001
VITE_APP_TITLE=OpenHand

# ---------------------------------------------------------------------------
# Sandbox / tool policy
# ---------------------------------------------------------------------------

# Allowed filesystem roots (colon-separated). Default: $OPENHAND_HOME/workspace
SANDBOX_FS_ROOTS=
# Hard timeout for any tool invocation in ms.
SANDBOX_TOOL_TIMEOUT_MS=15000
# Max bytes a tool may return.
SANDBOX_TOOL_MAX_OUTPUT_BYTES=1048576
# Require explicit approval before running dangerous tools (true|false).
SANDBOX_REQUIRE_APPROVAL=true

# ---------------------------------------------------------------------------
# Tools: email
# ---------------------------------------------------------------------------

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=

# ---------------------------------------------------------------------------
# Tools: browser / search
# ---------------------------------------------------------------------------

SEARCH_PROVIDER=duckduckgo
SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

LOG_LEVEL=info
# Set to 1 to write structured JSON logs.
LOG_JSON=0
