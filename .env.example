# OpenHand environment variables.
# Copy to `.env` and fill in real values. DO NOT commit `.env`.

# ---------------------------------------------------------------------------
# Core / agent
# ---------------------------------------------------------------------------

# Default LLM provider. Read by packages/llm `resolveProvider()`.
# One of: openai | anthropic | ollama (aliases: claude, local, custom)
LLM_PROVIDER=openai
# The model name passed verbatim to the provider.
OPENHAND_LLM_MODEL=gpt-4o-mini
# Request timeout in ms for any single LLM call (applies at LLMClient layer).
OPENHAND_LLM_TIMEOUT_MS=30000
# Client-side retry policy (LLMClient decorator).
OPENHAND_LLM_MAX_ATTEMPTS=3
OPENHAND_LLM_INITIAL_DELAY_MS=500
# Token-bucket rate limit (requests per minute). 0 disables.
OPENHAND_LLM_RPM=60
# Where the local config/state lives.
OPENHAND_HOME=~/.openhand

# ---------------------------------------------------------------------------
# LLM providers (only fill in the ones you use)
# ---------------------------------------------------------------------------

# OpenAI (also covers Azure, LiteLLM, vLLM, any OpenAI-compatible /v1 endpoint).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Messages API.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Ollama (local). Points at the native `/api/chat` endpoint, not the `/v1` shim.
OLLAMA_BASE_URL=http://localhost:11434

# Legacy / escape hatch: any provider that speaks the OpenAI wire format.
CUSTOM_LLM_BASE_URL=http://localhost:11434/v1
CUSTOM_LLM_API_KEY=ollama

# ---------------------------------------------------------------------------
# apps/server
# ---------------------------------------------------------------------------

SERVER_HOST=0.0.0.0
SERVER_PORT=3001
# CORS allowlist, comma separated; use "*" only for local dev.
SERVER_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# apps/web
# ---------------------------------------------------------------------------

VITE_API_BASE_URL=http://localhost:3001
VITE_APP_TITLE=OpenHand

# ---------------------------------------------------------------------------
# Sandbox / tool policy
# ---------------------------------------------------------------------------

# Allowed filesystem roots (colon-separated). Default: $OPENHAND_HOME/workspace
SANDBOX_FS_ROOTS=
# Hard timeout for any tool invocation in ms.
SANDBOX_TOOL_TIMEOUT_MS=15000
# Max bytes a tool may return.
SANDBOX_TOOL_MAX_OUTPUT_BYTES=1048576
# Require explicit approval before running dangerous tools (true|false).
SANDBOX_REQUIRE_APPROVAL=true

# ---------------------------------------------------------------------------
# Tools: email
# ---------------------------------------------------------------------------

EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=

# ---------------------------------------------------------------------------
# Tools: browser / search
# ---------------------------------------------------------------------------

SEARCH_PROVIDER=duckduckgo
SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

LOG_LEVEL=info
# Set to 1 to write structured JSON logs.
LOG_JSON=0
